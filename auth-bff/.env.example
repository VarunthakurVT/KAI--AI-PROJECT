# Upstream FastAPI (no trailing slash)
FASTAPI_UPSTREAM=http://127.0.0.1:8001

# BFF listen port
PORT=3001

# Comma-separated browser origins for CORS (Vite default 5173)
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Frontend callback target after Google login
FRONTEND_URL=http://localhost:5173

# Shared secret for Auth-BFF -> FastAPI internal OAuth handoff
AUTH_BFF_SHARED_SECRET=replace-with-a-long-random-string

# Google OAuth web app credentials
GOOGLE_CLIENT_ID=your-google-web-client-id
GOOGLE_CLIENT_SECRET=your-google-web-client-secret
GOOGLE_REDIRECT_URI=http://localhost:3001/auth/google/callback
